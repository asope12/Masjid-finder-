{
  "name": "masjid-finder",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "~19.1.10",
    "axios": "^1.6.7",
    "expo": "^54.0.0",
    "expo-clipboard": "~8.0.7",
    "expo-location": "~19.0.7",
    "expo-maps": "~0.12.8",
    "expo-sensors": "~15.0.7",
    "expo-speech": "~14.0.7",
    "expo-updates": "~29.0.12",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-dotenv": "^3.4.11",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.1"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "name": "Masjid Finder",
    "slug": "masjid-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon1.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5E2B8"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon1.png",
        "backgroundColor": "#F5E2B8"
      },
      "package": "com.yousef.masjidfinder",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon1.png"
    }
  }
}
